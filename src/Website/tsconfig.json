{
  "compileOnSave": false,
  "compilerOptions": {
    "baseUrl": "./",
    "outDir": "./dist/out-tsc",
    "sourceMap": true,
    "esModuleInterop": true,
    "declaration": false,
    "experimentalDecorators": true,
    "moduleResolution": "node",
    "importHelpers": true,
    "target": "ES2022",
    "module": "es2020",
    "resolveJsonModule": true,
    "lib": ["es2018", "dom"],
    "useDefineForClassFields": false,
    "paths": {
      "@assets/*": ["./src/assets/*"]
    },
    "skipLibCheck": true // TMP fix for Google Maps / broken .d.ts dependencies",
  }
}
